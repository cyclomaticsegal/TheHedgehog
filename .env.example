# The Hedgehog — API keys
#
# Copy this file to .env and fill in your keys.
# .env is gitignored and will never be committed.
# Keys are loaded at startup and written back to this file when you click Save
# in the sidebar. They are never stored in the database.
#
# FRED (Federal Reserve Economic Data) — required for VIX data
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage — daily spot prices for all commodities (Gold, Silver, BTC,
# WTI, Natural Gas, Copper, Aluminum, Wheat, Corn). Free tier: 25 req/day.
# Free key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# 51Folds — Bayesian model creation from hypothesis
# Get your key at: https://51folds.ai
FOLDS_API_KEY=at_sk_...

# AI Analysis (optional) — pick one provider to enable LLM-driven regime
# classification and hypothesis generation. The dashboard, charts, and
# 51Folds modelling all work without these; only the AI Analysis sidebar
# panel needs them. Uncomment the line for your chosen provider and fill
# in the key.
#
# Anthropic Claude — https://console.anthropic.com/
#ANTHROPIC_API_KEY=sk-ant-...
#
# OpenAI GPT — https://platform.openai.com/api-keys
#OPENAI_API_KEY=sk-...
